# =============================================================================
# OpenShell-on-Kubernetes launchable — configuration
# Copy to .env and fill in OPENSHELL_API_KEY. scripts/setup.sh reads this file,
# renders the Ansible secrets/overrides from it, and runs the playbook.
# (On Brev you can instead set these as the Launchable's environment variables.)
# =============================================================================

# ---- Inference (REQUIRED) ---------------------------------------------------
# Any OpenAI-compatible endpoint: NVIDIA API Catalog (build.nvidia.com), OpenAI,
# a self-hosted vLLM/NIM, or an internal gateway. The agent never sees this key —
# it calls https://inference.local; the in-sandbox proxy injects the credential.
OPENSHELL_API_KEY=""
OPENSHELL_BASE_URL="https://integrate.api.nvidia.com/v1"
OPENSHELL_MODEL="meta/llama-3.3-70b-instruct"

# ---- Stack toggles ----------------------------------------------------------
# gVisor (runsc) sandbox isolation. Strongly recommended — it's the security
# story for running untrusted agent code on a shared node.
ENABLE_GVISOR="true"

# Kyverno policy guardrails (incl. require-gvisor). Lightweight; good teaching aid.
ENABLE_KYVERNO="true"

# Full observability stack (Prometheus + Grafana + Loki + Alloy + Tempo).
# Grafana is published behind the Envoy ingress at <PUBLIC_BASE_URL>/grafana when
# SSO is on (see ENABLE_SSO); otherwise on NodePort 30030.
ENABLE_MONITORING="true"

# ---- Single sign-on + ingress (Keycloak + Envoy Gateway) --------------------
# Deploys Keycloak (OIDC), patches the kube-apiserver for OIDC RBAC, installs the
# Envoy Gateway, and path-routes the UIs under ONE public host:
#   <base>/auth (Keycloak)  <base>/grafana  <base>/headlamp  <base>/console
# plus Headlamp (k8s dashboard) and Grafana SSO. The OpenShell gateway gRPC is
# exposed via Envoy on ENVOY_GRPC_NODEPORT.
ENABLE_SSO="true"
# Headlamp Kubernetes dashboard (OIDC SSO). Off by default — kubectl + the
# console cover dashboarding; flip on if you want a full k8s web dashboard.
ENABLE_HEADLAMP="false"
# OpenShell Console (fleet/sandbox management UI) is built INTO the teaching site
# and served at <site>:WORKSHOP_PORT/console — no separate image or route needed.
# It talks to the gateway on GATEWAY_NODEPORT and runs in open mode (the gateway
# is unauthenticated). Nothing to toggle here.

# Public HTTPS base URL that fronts the Envoy web port (the OIDC issuer origin —
# must resolve identically from your browser, the gateway pod, and the apiserver).
# LEAVE EMPTY to auto-derive: https://<BREV_URL_PREFIX>-<brevid>.<BREV_URL_DOMAIN>
# (brevid is read from the host). Set PUBLIC_BASE_URL explicitly to override.
PUBLIC_BASE_URL=""
BREV_URL_PREFIX="openshell"
BREV_URL_DOMAIN="stg.apps.launchpad.nvidia.com"
# Envoy Gateway NodePorts: web (path-routed UIs) + gRPC (OpenShell gateway).
ENVOY_WEB_NODEPORT="30080"
ENVOY_GRPC_NODEPORT="30081"

# ---- Agent fleet ------------------------------------------------------------
# Create an initial fleet of OpenClaw sandboxes at the end of provisioning.
# Base default is 5 (lean). The Incident Desk needs 8 warm sandboxes (agent-0..7):
# its backend reuses agent-0..7 for coordinator + investigators + synthesizer +
# sender, so a missing one (e.g. agent-5) hangs a run. When ENABLE_INCIDENT_DESK=true
# (below) FLEET_SIZE is auto-forced to 8 — UNLESS you set FLEET_SIZE here, which
# always wins. Set it explicitly for a fixed pool regardless of the desk.
CREATE_FLEET="true"
FLEET_SIZE="5"

# Agent binary scripts/fleet execs inside a sandbox for `fleet task` (default:
# openclaw — the gateway's default sandbox image). For an OpenAI/LiteLLM backend
# use codex/opencode; for an Anthropic-format backend use claude.
AGENT_CMD="openclaw"

# ---- Teaching website -------------------------------------------------------
# A Next.js site (lessons + a live in-browser terminal wired to this cluster).
# Served on WORKSHOP_PORT — expose it on Brev to open it in your browser.
ENABLE_WORKSHOP="true"
WORKSHOP_PORT="3000"

# ---- Incident Desk (optional) ----------------------------------------------
# Deploys the FULL Incident Desk demo via the 18-incident-desk Ansible role:
#   - builds + imports the two :local images (research-desk-backend, orders-api)
#   - Gitea (in-cluster Git / GitOps source) + a `gitops` admin + the `gitops` org
#     + a Keycloak OAuth source; ArgoCD (pinned upstream); Mailpit; demo-shop
#     (orders-api + the GitOps catalog-api with a baked-in fault); the research-desk
#     backend that drives the OpenClaw fleet through the investigation
#   - seeds the FAULT GitOps catalog (CACHE_MB=400 → catalog-api OOM/CrashLoop live)
#   - exposes /gitea, /research-desk, /argocd, /mailpit behind the public host
# Default OFF — it's heavy and REQUIRES ENABLE_SSO=true (Keycloak + Envoy) and the
# warm agent-0..7 fleet. When true, FLEET_SIZE is auto-forced to 8 (see above).
# Re-runnable: every step is idempotent.
ENABLE_INCIDENT_DESK="false"

# ---- Networking -------------------------------------------------------------
# NodePort the OpenShell gateway is published on (expose this port on Brev for
# remote CLI access). Must be in 30000-32767.
GATEWAY_NODEPORT="30808"

# ---- Advanced ---------------------------------------------------------------
# Run only part of the playbook, e.g. ANSIBLE_TAGS=gateway (see ansible/README.md
# for the tag list). Leave empty for a full bring-up.
# ANSIBLE_TAGS=""
