apiVersion: v1
kind: Secret
metadata:
  name: openshell-ui-secrets
  namespace: {{ openshell_ui_namespace }}
type: Opaque
stringData:
  # Session/JWT encryption secret (set in secrets.yml: openssl rand -base64 32).
  AUTH_SECRET: "{{ openshell_ui_auth_secret }}"
  # Must equal the openshell-ui client secret in the realm (set in secrets.yml).
  OIDC_CLIENT_SECRET: "{{ openshell_ui_client_secret }}"
