apiVersion: apps/v1
kind: Deployment
metadata:
  name: openshell-ui
  namespace: {{ openshell_ui_namespace }}
  labels:
    app.kubernetes.io/name: openshell-ui
    app.kubernetes.io/part-of: openshell
spec:
  replicas: {{ openshell_ui_replicas }}
  selector:
    matchLabels:
      app.kubernetes.io/name: openshell-ui
  template:
    metadata:
      labels:
        app.kubernetes.io/name: openshell-ui
        app.kubernetes.io/part-of: openshell
    spec:
      securityContext:
        runAsNonRoot: true
        runAsUser: 1001
        runAsGroup: 1001
        fsGroup: 1001
        seccompProfile:
          type: RuntimeDefault
{% if openshell_ui_image_pull_secret | default('') | length > 0 %}
      imagePullSecrets:
        - name: {{ openshell_ui_image_pull_secret }}
{% endif %}
      volumes:
        - { name: cache, emptyDir: {} }
        - { name: tmp, emptyDir: {} }
      containers:
        - name: openshell-ui
          image: {{ openshell_ui_image }}
          imagePullPolicy: IfNotPresent
          ports:
            - { name: http, containerPort: 3000 }
          envFrom:
            - configMapRef: { name: openshell-ui-config }
            - secretRef: { name: openshell-ui-secrets }
          readinessProbe:
            httpGet: { path: "{{ openshell_ui_path }}", port: http }
            initialDelaySeconds: 5
            periodSeconds: 10
          livenessProbe:
            httpGet: { path: "{{ openshell_ui_path }}", port: http }
            initialDelaySeconds: 15
            periodSeconds: 20
          resources:
            requests: { cpu: "50m", memory: "128Mi" }
            limits: { cpu: "500m", memory: "512Mi" }
          securityContext:
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: true
            capabilities:
              drop: ["ALL"]
          volumeMounts:
            - { name: cache, mountPath: /app/.next/cache }
            - { name: tmp, mountPath: /tmp }
