# {{ openshell_ui_path }} → OpenShell Console, on the shared Envoy web listener.
# Co-located with the Service (same namespace) so no ReferenceGrant is needed.
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: openshell-ui
  namespace: {{ openshell_ui_namespace }}
spec:
  parentRefs:
    - name: fleet-gw
      namespace: {{ envoy_gateway_ns }}
      sectionName: web
  rules:
    - matches:
        - path: { type: PathPrefix, value: "{{ openshell_ui_path }}" }
      filters:
        # TLS terminates at the edge; tell the app the original scheme is https
        # so Auth.js builds an https OIDC redirect_uri matching the registered URI.
        - type: RequestHeaderModifier
          requestHeaderModifier:
            set:
              - { name: X-Forwarded-Proto, value: "https" }
      backendRefs:
        - name: openshell-ui
          port: 80
