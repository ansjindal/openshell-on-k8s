# /grafana → Grafana (Grafana serves under root_url + serve_from_sub_path).
# In the monitoring namespace (co-located with the Service) → no ReferenceGrant.
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: grafana
  namespace: monitoring
spec:
  parentRefs:
    - name: fleet-gw
      namespace: {{ envoy_gateway_ns }}
      sectionName: web
  rules:
    - matches:
        - path: { type: PathPrefix, value: "{{ grafana_path }}" }
      filters:
        - type: RequestHeaderModifier
          requestHeaderModifier:
            set:
              - { name: X-Forwarded-Proto, value: "https" }
      backendRefs:
        - name: kps-grafana
          port: 80
