# /auth → Keycloak (Keycloak serves under KC_HTTP_RELATIVE_PATH, so no rewrite).
# In the keycloak namespace (co-located with the Service) → no ReferenceGrant.
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: keycloak-auth
  namespace: {{ keycloak_namespace }}
spec:
  parentRefs:
    - name: fleet-gw
      namespace: {{ envoy_gateway_ns }}
      sectionName: web
  rules:
    - matches:
        - path: { type: PathPrefix, value: "{{ keycloak_relative_path }}" }
      filters:
        - type: RequestHeaderModifier
          requestHeaderModifier:
            set:
              - { name: X-Forwarded-Proto, value: "https" }
      backendRefs:
        - name: keycloak
          port: 8080
