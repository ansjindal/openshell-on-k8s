# /mailpit → Mailpit web UI (the Incident Desk's mail sink; svc mailpit:8025).
# In the research-desk namespace (co-located with the Service) → no ReferenceGrant.
#
# Mailpit runs with MP_WEBROOT=/mailpit (see incident-desk/deploy/mailpit.yaml), so it
# serves its UI/assets/API/websocket under /mailpit and emits data-webroot=/mailpit/.
# Therefore we must NOT strip the prefix — the backend needs to receive /mailpit/... so
# its webroot matches (stripping → root would break the SPA's /mailpit-prefixed assets).
# Mailpit only serves the app under the trailing-slash path, so redirect the exact
# bare /mailpit → /mailpit/ (mirrors the headlamp route). X-Forwarded-Proto=https so
# links/assets are built for the https edge (TLS terminates at Envoy).
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: mailpit
  namespace: {{ mailpit_namespace }}
spec:
  parentRefs:
    - name: fleet-gw
      namespace: {{ envoy_gateway_ns }}
      sectionName: web
  rules:
    - matches:
        - path: { type: Exact, value: "{{ mailpit_path }}" }
      filters:
        - type: RequestRedirect
          requestRedirect:
            path: { type: ReplaceFullPath, replaceFullPath: "{{ mailpit_path }}/" }
            statusCode: 302
    - matches:
        - path: { type: PathPrefix, value: "{{ mailpit_path }}" }
      filters:
        - type: RequestHeaderModifier
          requestHeaderModifier:
            set:
              - { name: X-Forwarded-Proto, value: "https" }
      backendRefs:
        - name: mailpit
          port: {{ mailpit_ui_port }}
