# EnvoyProxy: per-Gateway data-plane config. k3s has no LoadBalancer, so pin the
# Envoy Service to NodePort, one per listener:
#   {{ envoy_web_nodeport }}  -> web (HTTP, :80)   path routes: /auth /grafana /headlamp
#   {{ envoy_grpc_nodeport }} -> grpc (:8080)      OpenShell gateway (gRPC)
# The single public host points at the web NodePort.
apiVersion: gateway.envoyproxy.io/v1alpha1
kind: EnvoyProxy
metadata:
  name: fleet-envoy
  namespace: {{ envoy_gateway_ns }}
spec:
  provider:
    type: Kubernetes
    kubernetes:
      envoyService:
        type: NodePort
        patch:
          type: StrategicMerge
          value:
            spec:
              ports:
                # Privileged port 80: Envoy non-root binds port+10000 (10080).
                - name: http-80
                  port: 80
                  protocol: TCP
                  targetPort: 10080
                  nodePort: {{ envoy_web_nodeport }}
                # Ports > 1024 bind directly.
                - name: grpc-8080
                  port: 8080
                  protocol: TCP
                  targetPort: 8080
                  nodePort: {{ envoy_grpc_nodeport }}
      envoyDeployment:
        replicas: 1
        container:
          resources:
            requests:
              cpu: 100m
              memory: 128Mi
            limits:
              memory: 512Mi
