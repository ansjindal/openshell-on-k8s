apiVersion: v1
kind: Service
metadata:
  name: keycloak
  namespace: {{ keycloak_namespace }}
  labels: { app: keycloak }
spec:
  # ClusterIP only — Keycloak is exposed publicly via the Envoy /auth route,
  # never a direct NodePort.
  type: ClusterIP
  selector: { app: keycloak }
  ports:
    - name: http
      port: 8080
      targetPort: 8080
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: keycloak
  namespace: {{ keycloak_namespace }}
  labels: { app: keycloak }
spec:
  replicas: 1
  selector:
    matchLabels: { app: keycloak }
  template:
    metadata:
      labels: { app: keycloak }
      annotations:
        realm-checksum: "{{ realm_checksum | default('0') }}"
    spec:
      containers:
        - name: keycloak
          image: {{ keycloak_image }}
          args: ["start-dev", "--import-realm"]
          env:
            - name: KC_BOOTSTRAP_ADMIN_USERNAME
              value: "{{ keycloak_admin_user }}"
            - name: KC_BOOTSTRAP_ADMIN_PASSWORD
              valueFrom:
                secretKeyRef: { name: keycloak-admin, key: password }
            - name: KC_HTTP_ENABLED
              value: "true"
            - name: KC_HOSTNAME_STRICT
              value: "false"
{% if keycloak_base_url | length > 0 %}
            # Pin the public host + path so tokens carry a stable issuer
            # (<base>/auth/realms/...). KC_HOSTNAME must INCLUDE the path or the
            # issuer claim omits it; KC_HTTP_RELATIVE_PATH makes Keycloak serve there.
            - name: KC_HOSTNAME
              value: "{{ keycloak_base_url }}{{ keycloak_relative_path }}"
            - name: KC_HTTP_RELATIVE_PATH
              value: "{{ keycloak_relative_path }}"
{% endif %}
            - name: KC_PROXY_HEADERS
              value: "xforwarded"
            - name: KC_HEALTH_ENABLED
              value: "true"
          ports:
            - { name: http, containerPort: 8080 }
            - { name: mgmt, containerPort: 9000 }
          volumeMounts:
            - name: realm-import
              mountPath: /opt/keycloak/data/import
              readOnly: true
          readinessProbe:
            # KC_HTTP_RELATIVE_PATH also shifts the management health endpoint.
            httpGet: { path: "{{ (keycloak_relative_path ~ '/health/ready') if (keycloak_base_url | length > 0) else '/health/ready' }}", port: 9000 }
            initialDelaySeconds: 20
            periodSeconds: 10
            failureThreshold: 30
          resources:
            requests: { cpu: 200m, memory: 512Mi }
            limits: { memory: 1Gi }
      volumes:
        - name: realm-import
          configMap:
            name: keycloak-realm
